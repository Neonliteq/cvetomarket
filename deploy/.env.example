# =============================================================================
# ЦветоМаркет — Переменные окружения для production
# =============================================================================
# Скопируйте в .env и заполните реальными значениями:
#   cp deploy/.env.example .env
#   nano .env
# =============================================================================

# -----------------------------------------------------------------------------
# Приложение
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=5000

# -----------------------------------------------------------------------------
# База данных (PostgreSQL)
# Формат: postgresql://пользователь:пароль@хост:порт/имя_базы
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://cvetomarket:ВАШИЙ_ПАРОЛЬ@localhost:5432/cvetomarket

# -----------------------------------------------------------------------------
# Сессии
# Генерируйте случайную строку: openssl rand -hex 32
# -----------------------------------------------------------------------------
SESSION_SECRET=СГЕНЕРИРУЙТЕ_СЛУЧАЙНУЮ_СТРОКУ_32_СИМВОЛА

# -----------------------------------------------------------------------------
# Reg.ru Object Storage (S3-совместимый)
# Создайте бакет в панели Reg.ru → Облачное хранилище
# Эндпоинт для Reg.ru S3: https://s3.regru.ru
# -----------------------------------------------------------------------------
REGRU_S3_ACCESS_KEY=ВАШ_ACCESS_KEY
REGRU_S3_SECRET_KEY=ВАШ_SECRET_KEY
REGRU_S3_BUCKET=ИМЯ_ВАШЕГО_БАКЕТА
REGRU_S3_ENDPOINT=https://s3.regru.ru
REGRU_S3_REGION=ru-1

# -----------------------------------------------------------------------------
# Telegram Bot (уведомления о заказах)
# Создайте бота через @BotFather: https://t.me/BotFather
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=ТОКЕН_ВАШЕГО_TELEGRAM_БОТА

# -----------------------------------------------------------------------------
# Яндекс Карты (геокодинг, карта доставки)
# Получите ключ: https://developer.tech.yandex.ru/
# ВАЖНО: ключ должен начинаться с VITE_ чтобы быть доступным на фронтенде
# -----------------------------------------------------------------------------
VITE_YANDEX_MAPS_API_KEY=ВАШ_ЯНДЕКС_КЛЮЧ

# -----------------------------------------------------------------------------
# ROBOKASSA (приём платежей картой)
# Зарегистрируйтесь: https://robokassa.com/
# ROBOKASSA_IS_TEST=0  — боевой режим
# ROBOKASSA_IS_TEST=1  — тестовый режим
# -----------------------------------------------------------------------------
ROBOKASSA_LOGIN=ВАШ_ЛОГИН_В_ROBOKASSA
ROBOKASSA_PASSWORD1=ВАШ_PASSWORD1
ROBOKASSA_PASSWORD2=ВАШ_PASSWORD2
ROBOKASSA_IS_TEST=0

# -----------------------------------------------------------------------------
# Resend (отправка email: сброс пароля и т.д.)
# Получите API ключ: https://resend.com/
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
